<%= form_with url: imports_path, multipart: true do |f| %>
    <div>
      <p>
        Select CSV File
      </p>
      <%= f.file_field :file, accept: ".csv", style: "color: #94a3b8; font-size: 13px;" %>
    </div>

    <div>
      <p>
        Expected Columns
      </p>
      <p>
        Customer, Supplier, Quote, Tax Included, State, Tax Rate
      </p>
    </div>

    <%= f.submit "Import CSV", style: "background-color: #2563eb; color: white; font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 10px 24px; border: none; cursor: pointer;" %>
<% end %>
